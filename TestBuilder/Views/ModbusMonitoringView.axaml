<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TestBuilder.ViewModels"
             xmlns:models="using:TestBuilder.Domain.Modbus.Models"
             xmlns:converters="using:TestBuilder.Converters"
             x:Class="TestBuilder.Views.ModbusMonitoringView"
             x:DataType="vm:ModbusMonitoringViewModel">

  <DockPanel Background="{DynamicResource AppBackgroundBrush}">

    <Border DockPanel.Dock="Top"
            Margin="14"
            Padding="14"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            BoxShadow="0 8 24 0 #100F172A">

      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Content="Сканировать"
                Classes="primary"
                Command="{Binding ScanCommand}"
                IsEnabled="{Binding !IsScanning}" />

        <Border Background="#FEF2F2"
                BorderBrush="#FECACA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,7"
                IsVisible="{Binding !IsConnected}">
          <TextBlock Text="Нет подключения. Подключитесь на вкладке Тест."
                     Foreground="#991B1B"
                     VerticalAlignment="Center" />
        </Border>

        <Border Background="#EFF6FF"
                BorderBrush="#BFDBFE"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,7"
                IsVisible="{Binding IsScanning}">
          <TextBlock Text="Сканирование..."
                     Foreground="#1D4ED8"
                     VerticalAlignment="Center" />
        </Border>

        <Border Background="#ECFDF5"
                BorderBrush="#A7F3D0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,7"
                IsVisible="{Binding IsMonitoring}">
          <TextBlock Text="Мониторинг запущен"
                     Foreground="#047857"
                     VerticalAlignment="Center" />
        </Border>
      </StackPanel>
    </Border>

    <TextBlock DockPanel.Dock="Top"
               Text="Устройства не найдены. Подключите железо и нажмите Сканировать."
               IsVisible="{Binding !Slaves.Count}"
               Margin="18,0,18,12"
               Foreground="{DynamicResource TextSecondaryBrush}" />

    <Grid ColumnDefinitions="*,330"
          Margin="14,0,14,14">

      <ScrollViewer Grid.Column="0"
                    Background="Transparent"
                    x:Name="MainScrollViewer"
                    BringIntoViewOnFocusChange="False">

        <ItemsControl ItemsSource="{Binding Slaves}"
                      HorizontalAlignment="Stretch">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>

          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="models:SlaveModelBase">
              <Border Margin="0,0,12,12"
                      Padding="12"
                      BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="1"
                      CornerRadius="14"
                      Background="{DynamicResource SurfaceBrush}"
                      Width="620"
                      BoxShadow="0 6 18 0 #0D0F172A">

                <Grid RowDefinitions="Auto,Auto">

                  <Grid Grid.Row="0"
                        ColumnDefinitions="*,Auto"
                        Margin="0,0,0,10">

                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock FontWeight="Bold"
                                 FontSize="15"
                                 Text="{Binding DeviceType}"
                                 Foreground="{DynamicResource TextPrimaryBrush}" />
                      <TextBlock Text="{Binding SlaveId, StringFormat='Slave ID: {0}'}"
                                 Foreground="{DynamicResource TextSecondaryBrush}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="{Binding ToggleIcon}"
                            Command="{Binding ToggleExpandedCommand}"
                            VerticalAlignment="Center"
                            Classes="ghost"
                            Padding="10,6" />
                  </Grid>

                  <DataGrid Grid.Row="1"
                            IsVisible="{Binding IsExpanded}"
                            ItemsSource="{Binding RegisterItems}"
                            DoubleTapped="OnDataGridDoubleTapped"
                            AutoGenerateColumns="False"
                            IsReadOnly="True"
                            GridLinesVisibility="Horizontal"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource BorderBrush}"
                            CanUserResizeColumns="True"
                            CanUserSortColumns="True"
                            Height="{Binding GridHeight}">
                    <DataGrid.Resources>
                      <converters:BoolToBackgroundConverter x:Key="BoolToBackground" />
                    </DataGrid.Resources>

                    <DataGrid.Styles>
                      <Style Selector="DataGridRow">
                        <Setter Property="Background">
                          <Setter.Value>
                            <Binding Path="IsReadOnly"
                                     Converter="{StaticResource BoolToBackground}"
                                     x:DataType="models:RegisterItem" />
                          </Setter.Value>
                        </Setter>
                      </Style>

                      <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
                        <Setter Property="Fill" Value="Transparent" />
                      </Style>
                    </DataGrid.Styles>

                    <DataGrid.Columns>
                      <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="80" />
                      <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*" />
                      <DataGridTextColumn Header="Значение" Binding="{Binding Value, Mode=OneWay}" Width="90" />
                      <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="130" />
                    </DataGrid.Columns>
                  </DataGrid>

                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <Border Grid.Column="1"
              Background="{DynamicResource SidebarDarkBrush}"
              BorderBrush="{DynamicResource SidebarBorderBrush}"
              BorderThickness="1"
              CornerRadius="14"
              Padding="12"
              ClipToBounds="True">

        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0"
                     Text="Логи Modbus"
                     FontWeight="SemiBold"
                     FontSize="14"
                     Foreground="{DynamicResource SidebarTextBrush}"
                     Margin="0,0,0,8" />

          <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding TestingLogger.Entries}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding}"
                             FontFamily="Consolas"
                             FontSize="11"
                             Foreground="{DynamicResource SidebarTextMutedBrush}"
                             Margin="2,2"
                             TextWrapping="Wrap" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>

      </Border>

    </Grid>
  </DockPanel>
</UserControl>
