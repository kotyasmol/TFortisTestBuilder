<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TestBuilder.ViewModels"
             xmlns:models="using:TestBuilder.Domain.Modbus.Models"
             xmlns:converters="using:TestBuilder.Converters"
             x:Class="TestBuilder.Views.ModbusMonitoringView"
             x:DataType="vm:ModbusMonitoringViewModel">

    <DockPanel>

        <!-- Панель управления сверху -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5" Spacing="10">
            <Button Content="Сканировать"
                    Command="{Binding ScanCommand}"
                    IsEnabled="{Binding !IsScanning}" />
            <TextBlock Text="Нет подключения. Подключитесь на вкладке Тест."
                       IsVisible="{Binding !IsConnected}"
                       Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
                       VerticalAlignment="Center" />
            <TextBlock Text="Сканирование..."
                       IsVisible="{Binding IsScanning}"
                       VerticalAlignment="Center" />
            <TextBlock Text="Мониторинг запущен"
                       IsVisible="{Binding IsMonitoring}"
                       Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>

        <!-- Пустое состояние -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Устройства не найдены. Подключите железо и нажмите Сканировать."
                   IsVisible="{Binding !Slaves.Count}"
                   Margin="10"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />

        <!-- Основной контент -->
        <Grid ColumnDefinitions="*,300">

            <!-- Левая часть -->
            <ScrollViewer Grid.Column="0" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" x:Name="MainScrollViewer"
                          BringIntoViewOnFocusChange="False">
                <ItemsControl ItemsSource="{Binding Slaves}"
                              HorizontalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:SlaveModelBase">
                            <Border Margin="5" Padding="5" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" Width="600">
                                <Grid RowDefinitions="Auto,Auto">
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,5">
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontWeight="Bold" Text="{Binding DeviceType}" />
                                            <TextBlock Text="{Binding SlaveId, StringFormat='Slave ID: {0}'}" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="{Binding ToggleIcon}"
                                                Command="{Binding ToggleExpandedCommand}"
                                                VerticalAlignment="Center"
                                                Padding="8,4" />
                                    </Grid>
                                    <DataGrid Grid.Row="1"
                                              IsVisible="{Binding IsExpanded}"
                                              ItemsSource="{Binding RegisterItems}"
                                              DoubleTapped="OnDataGridDoubleTapped"
                             
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              GridLinesVisibility="All"
                                              BorderThickness="1"
                                              BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                              CanUserResizeColumns="True"
                                              CanUserSortColumns="True"
                                              Height="{Binding GridHeight}">
                                        <DataGrid.Resources>
                                            <converters:BoolToBackgroundConverter x:Key="BoolToBackground" />
                                        </DataGrid.Resources>
                                        <DataGrid.Styles>
                                            <!-- Цвет строки по IsReadOnly -->
                                            <Style Selector="DataGridRow">
                                                <Setter Property="Background">
                                                    <Setter.Value>
                                                        <Binding Path="IsReadOnly"
                                                                 Converter="{StaticResource BoolToBackground}"
                                                                 x:DataType="models:RegisterItem" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                            <!-- Убираем подсветку выделения -->
                                            <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
                                                <Setter Property="Fill" Value="Transparent" />
                                            </Style>
                                        </DataGrid.Styles>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="80" />
                                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*" />
                                            <DataGridTextColumn Header="Значение" Binding="{Binding Value, Mode=OneWay}" Width="80" />
                                            <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Правая панель — логи -->
            <DockPanel Grid.Column="1" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                <TextBlock DockPanel.Dock="Top"
                           Text="Логи"
                           FontWeight="Bold"
                           Margin="8,8,8,4" />
                <Border DockPanel.Dock="Top"
                        Height="1"
                        Background="{DynamicResource SystemControlForegroundBaseLowBrush}"
                        Margin="0,0,0,4" />
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding TestingLogger.Entries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Margin="5,1"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

        </Grid>

    </DockPanel>

</UserControl>