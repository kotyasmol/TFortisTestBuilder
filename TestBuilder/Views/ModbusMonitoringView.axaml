<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TestBuilder.ViewModels"
             xmlns:models="using:TestBuilder.Domain.Modbus.Models"
             x:Class="TestBuilder.Views.ModbusMonitoringView"
             x:DataType="vm:ModbusMonitoringViewModel">

	<DockPanel>

		<!-- Панель управления сверху -->
		<StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5" Spacing="10">
			<Button Content="Сканировать"
                    Command="{Binding ScanCommand}"
                    IsEnabled="{Binding !IsScanning}" />
			<TextBlock Text="Нет подключения. Подключитесь на вкладке Тест."
                       IsVisible="{Binding !IsConnected}"
                       Foreground="Red"
                       VerticalAlignment="Center" />
			<TextBlock Text="Сканирование..."
                       IsVisible="{Binding IsScanning}"
                       VerticalAlignment="Center" />
			<TextBlock Text="Мониторинг запущен"
                       IsVisible="{Binding IsMonitoring}"
                       Foreground="Green"
                       VerticalAlignment="Center" />
		</StackPanel>

		<!-- Пустое состояние -->
		<TextBlock DockPanel.Dock="Top"
                   Text="Устройства не найдены. Подключите железо и нажмите Сканировать."
                   IsVisible="{Binding !Slaves.Count}"
                   Margin="10"
                   Foreground="Gray" />
        <!-- Логи из вкладки Тест -->
        <Border DockPanel.Dock="Bottom"
                Height="150"
                BorderBrush="Gray"
                BorderThickness="0,1,0,0">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding TestingLogger.Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Margin="5,1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

		<!-- Список устройств -->
		 <ScrollViewer>
			<ItemsControl ItemsSource="{Binding Slaves}"
                          HorizontalAlignment="Stretch">

				<ItemsControl.ItemsPanel>
					<ItemsPanelTemplate>
						<WrapPanel Orientation="Horizontal"/>
					</ItemsPanelTemplate>
				</ItemsControl.ItemsPanel>

				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="models:SlaveModelBase">
						<Border Margin="5" Padding="5" BorderBrush="Gray" BorderThickness="1" Width="550">
                            <Grid RowDefinitions="Auto,Auto">
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,5">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock FontWeight="Bold" Text="{Binding DeviceType}" />
                                        <TextBlock Text="{Binding SlaveId, StringFormat='Slave ID: {0}'}" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="{Binding ToggleIcon}"
                                            Command="{Binding ToggleExpandedCommand}"
                                            VerticalAlignment="Center"
                                            Padding="8,4" />
                                </Grid>
                                <DataGrid Grid.Row="1"
                                          IsVisible="{Binding IsExpanded}"
                                          ItemsSource="{Binding RegisterItems}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          GridLinesVisibility="All"
                                          BorderThickness="1"
                                          BorderBrush="Gray"
                                          CanUserResizeColumns="True"
                                          CanUserSortColumns="True">
									<DataGrid.Columns>
										<DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="80" />
										<DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" />
										<DataGridTextColumn Header="Value" Binding="{Binding Value, Mode=OneWay}" Width="80" />
										<DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*" />
									</DataGrid.Columns>
								</DataGrid>
							</Grid>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>

			</ItemsControl>
		</ScrollViewer>

	</DockPanel>

</UserControl>