<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TestBuilder.ViewModels"
             xmlns:logging="using:TestBuilder.Services.Logging"
             x:Class="TestBuilder.Views.TestView"
             x:DataType="vm:TestViewModel"
             Width="500"
             Height="400">

    <StackPanel Spacing="12" >

        <!-- Кнопка подключения/отключения -->
        <Button Content="{Binding ConnectionButtonText}"
                Command="{Binding ToggleConnectionCommand}"
                HorizontalAlignment="Stretch"
                Height="60"
                FontSize="16"
                FontWeight="SemiBold" />

        <!-- Статус -->
        <TextBlock Text="{Binding StatusMessage}"
                   Margin="0,8"
                   TextWrapping="Wrap"
                   FontSize="14" />

        <!-- Лог с прокруткой -->
        <Border BorderThickness="1"
                BorderBrush="Gray"
                CornerRadius="4"
                Padding="4"
                VerticalAlignment="Stretch">
            <ScrollViewer Name="LogScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Height="280">
                <ItemsControl Name="LogItemsControl"
                              ItemsSource="{Binding TestingLogger.Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="logging:LogEntry">
                            <TextBlock Text="{Binding}"
                                       Margin="2"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

    </StackPanel>
</UserControl>
