<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TestBuilder.ViewModels"
        xmlns:views="using:TestBuilder.Views"
        x:Class="TestBuilder.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1366"
        Height="800"
        Title="TestBuilder">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <DockPanel>
        <TabControl DockPanel.Dock="Top">
            <TabItem Header="Тест">
                <views:TestView x:Name="TestViewControl" />
            </TabItem>
            <TabItem Header="Modbus" IsEnabled="{Binding IsSlavesFound}">
                <views:ModbusMonitoringView x:Name="ModbusViewControl" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
