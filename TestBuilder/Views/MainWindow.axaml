<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TestBuilder.ViewModels"
        xmlns:views="using:TestBuilder.Views"
        x:Class="TestBuilder.Views.MainWindow"
        Width="900"
        Height="650"
        Title="TestBuilder">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <DockPanel>

        <!-- Верхнее меню / вкладки -->
        <TabControl DockPanel.Dock="Top">
            <TabItem Header="Тест">
                <views:TestView />
            </TabItem>
            <TabItem Header="пустая вкладка">
                <TextBlock Text="Здесь будет другой функционал" />
            </TabItem>
        </TabControl>

    </DockPanel>
</Window>
