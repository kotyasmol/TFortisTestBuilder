<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TestBuilder.Views.ConnectionLostDialog"
        Title="Обрыв связи"
        Width="380"
        Height="180"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <StackPanel Margin="24" Spacing="16">
        <TextBlock Text="Связь с устройством потеряна."
                   FontSize="15"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap" />

        <TextBlock Text="Попробовать переподключиться?"
                   FontSize="13"
                   Opacity="0.7"
                   TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="10"
                    Margin="0,8,0,0">
            <Button Content="Да, переподключить"
                    Width="160"
                    Click="OnReconnect" />
            <Button Content="Нет, отключиться"
                    Width="140"
                    Click="OnDisconnect" />
        </StackPanel>
    </StackPanel>

</Window>
