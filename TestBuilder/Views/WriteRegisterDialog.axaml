<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TestBuilder.Views.WriteRegisterDialog"
        Title="Write Single Register"
        Width="300"
        Height="250"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <StackPanel Margin="15" Spacing="10">

        <Grid ColumnDefinitions="100,*">
            <TextBlock Grid.Column="0" Text="Slave ID:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" x:Name="SlaveIdBox" />
        </Grid>

        <Grid ColumnDefinitions="100,*">
            <TextBlock Grid.Column="0" Text="Address:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" x:Name="AddressBox" IsReadOnly="True" />
        </Grid>

        <Grid ColumnDefinitions="100,*">
            <TextBlock Grid.Column="0" Text="Value:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" x:Name="ValueBox" />
        </Grid>

        <Border Height="1" Background="Gray" Margin="0,5" />

        <TextBlock x:Name="ResultText" Text="N/A" Foreground="Gray" />

        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button Content="Send" x:Name="SendButton" Width="80" />
            <Button Content="Cancel" x:Name="CancelButton" Width="80" />
        </StackPanel>

    </StackPanel>
</Window>