<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TestBuilder.Views.WriteRegisterDialog"
        Title="Запись регистра"
        Width="300"
        Height="250"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <StackPanel Margin="15" Spacing="10">

        <Grid ColumnDefinitions="100,*">
            <TextBlock Grid.Column="0" Text="Slave ID:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" x:Name="SlaveIdBox" />
        </Grid>

        <Grid ColumnDefinitions="100,*">
            <TextBlock Grid.Column="0" Text="Адрес:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" x:Name="AddressBox" IsReadOnly="True" />
        </Grid>

        <Grid ColumnDefinitions="100,*">
            <TextBlock Grid.Column="0" Text="Значение:" VerticalAlignment="Center" />
            <TextBox Grid.Column="1" x:Name="ValueBox" />
        </Grid>

        <Border Height="1" Background="Gray" Margin="0,5" />

        <TextBlock x:Name="ResultText" Text="Нет данных" Foreground="Gray" />

        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button Content="Отправить" x:Name="SendButton" Width="100" />
            <Button Content="Отмена" x:Name="CancelButton" Width="90" />
        </StackPanel>

    </StackPanel>
</Window>