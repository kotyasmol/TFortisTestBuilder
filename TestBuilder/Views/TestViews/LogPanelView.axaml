<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TestBuilder.ViewModels"
             xmlns:logging="using:TestBuilder.Services.Logging"
             xmlns:converters="using:TestBuilder.Converters"
             x:Class="TestBuilder.Views.TestViews.LogPanelView"
             x:DataType="vm:TestViewModel">

    <UserControl.Resources>
        <converters:NullableColorConverter x:Key="NullableColor" />
    </UserControl.Resources>

    <Border BorderThickness="1,0,0,0"
            BorderBrush="#2A2A2E"
            Padding="8,6"
            Background="{DynamicResource SystemControlBackgroundAltMediumHighBrush}">
        <Grid RowDefinitions="Auto,*">
            <TextBlock Grid.Row="0"
                       Text="Логи"
                       FontSize="11"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                       Margin="0,0,0,4" />

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <ItemsControl x:Name="LogsList"
                              ItemsSource="{Binding TestingLogger.Entries}"
                              Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="logging:LogEntry">
                            <TextBlock Margin="2"
                                       TextWrapping="Wrap"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Text="{Binding}"
                                       Foreground="{Binding HighlightColor, Converter={StaticResource NullableColor}, TargetNullValue={DynamicResource SystemControlForegroundBaseHighBrush}}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>

</UserControl>
