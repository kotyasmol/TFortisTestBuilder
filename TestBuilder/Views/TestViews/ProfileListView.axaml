<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TestBuilder.ViewModels"
             x:Class="TestBuilder.Views.TestViews.ProfileListView"
             x:DataType="vm:TestViewModel">

    <Grid RowDefinitions="Auto,Auto,*">
        <TextBlock Grid.Row="0"
                   Text="Профили тестирования"
                   FontSize="12"
                   Opacity="0.7"
                   Margin="0,0,0,4" />

        <TextBox Grid.Row="1"
                 Text="{Binding ProfileSearch}"
                 Watermark="Поиск по названию..."
                 Margin="0,0,0,4" />

        <Border Grid.Row="2"
                BorderThickness="1"
                BorderBrush="#2A2A2E"
                CornerRadius="4">
            <ListBox x:Name="ProfileListBox"
                     ItemsSource="{Binding Profiles}"
                     SelectedItem="{Binding SelectedProfile}"
                     Background="Transparent"
                     SelectionChanged="OnProfileSelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"
                                   Padding="4,2"
                                   TextWrapping="Wrap" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>

</UserControl>
