<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TestBuilder.ViewModels"
             xmlns:nodifyvm="using:TestBuilder.ViewModels.NodifyVM"
             x:Class="TestBuilder.Views.TestViews.NodePaletteView"
             x:DataType="vm:TestViewModel">

  <Border CornerRadius="14"
          BorderThickness="1"
          BorderBrush="{DynamicResource SidebarBorderBrush}"
          Background="{DynamicResource SidebarDarkBrush}"
          ClipToBounds="True"
          BoxShadow="0 12 28 0 #33000000">

    <Grid RowDefinitions="Auto,*">

      <Border Grid.Row="0"
              Background="{DynamicResource SidebarDarkAltBrush}"
              Padding="14,12"
              BorderBrush="{DynamicResource SidebarBorderBrush}"
              BorderThickness="0,0,0,1">

        <StackPanel Spacing="2">
          <TextBlock Text="Ноды"
                     FontSize="14"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource SidebarTextBrush}" />

          <TextBlock Text="Перетащи элемент на граф"
                     FontSize="11"
                     Foreground="{DynamicResource SidebarTextMutedBrush}" />
        </StackPanel>
      </Border>

      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled">

        <ItemsControl ItemsSource="{Binding AvailableNodes}"
                      Margin="10">

          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="nodifyvm:NodeViewModel">

              <Border Margin="0,5"
                      Padding="10,8"
                      CornerRadius="9"
                      Background="#F8FAFC"
                      BorderBrush="#3B82F6"
                      BorderThickness="1.5"
                      PointerPressed="OnNodePressed"
                      PointerMoved="OnNodeDrag"
                      PointerExited="OnNodeExited">

                <Grid ColumnDefinitions="Auto,*">

                  <Border Grid.Column="0"
                          Width="9"
                          Height="9"
                          CornerRadius="5"
                          Background="#3B82F6"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0" />

                  <TextBlock Grid.Column="1"
                             Text="{Binding Title}"
                             FontSize="13"
                             FontWeight="SemiBold"
                             Foreground="#0F172A"
                             TextWrapping="Wrap"
                             VerticalAlignment="Center" />

                </Grid>
              </Border>

            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

    </Grid>
  </Border>
</UserControl>